# 모든 텍스트 파일: 저장소에 LF, Windows 체크아웃 시에도 LF 유지
* text=auto eol=lf

# 명시적으로 LF 강제
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# 바이너리 파일은 변환 없음
*.png   binary
*.jpg   binary
*.pdf   binary
*.zip   binary
